+                            <div className="flex items-center gap-2 text-accent font-bold text-[10px] uppercase animate-in fade-in zoom-in duration-500">
+                                <CheckCircle2 className="h-4 w-4" /> E-mail cadastrado!
+                            </div>
+                        ) : (
+                            <>
+                                <input
+                                    type="email"
+                                    placeholder="Seu melhor e-mail"
+                                    className="bg-white/5 border border-white/10 p-3.5 rounded-xl text-xs flex-1 outline-none focus:ring-1 focus:ring-accent text-white"
+                                    value={email}
+                                    onChange={(e) => setEmail(e.target.value)}
+                                    disabled={isSubmitting}
+                                />
+                                <button
+                                    onClick={async () => {
+                                        if (!email) return;
+                                        setIsSubmitting(true);
+                                        const { error } = await supabase.from('leads').insert({
+                                            name: 'Newsletter Subscriber',
+                                            customer_whatsapp: 'E-mail: ' + email,
+                                            message: 'Inscrito via Newsletter no Rodap├®',
+                                            status: 'novo'
+                                        });
+                                        if (!error) {
+                                            setIsSuccess(true);
+                                            setEmail('');
+                                            setTimeout(() => setIsSuccess(false), 3000);
+                                        }
+                                        setIsSubmitting(false);
+                                    }}
+                                    disabled={isSubmitting}
+                                    className="bg-accent text-white p-3.5 rounded-xl hover:bg-white hover:text-primary-900 transition-all active:scale-95 shadow-lg shadow-accent/20 flex items-center justify-center min-w-[48px]"
+                                >
+                                    {isSubmitting ? <Loader2 className="h-4 w-4 animate-spin" /> : <ArrowRight className="h-4 w-4" />}
+                                </button>
+                            </>
+                        )}
                     </div>
                 </div>
             </div>

